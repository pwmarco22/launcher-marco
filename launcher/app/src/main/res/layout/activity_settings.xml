<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0c29">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="32dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/circle_button_bg"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MARCO Settings"
                android:textSize="24sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- Live Wallpaper -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WALLPAPER" android:textSize="11sp" android:textColor="#88ffffff"
            android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1a1a2e" app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Live Wallpaper" android:textColor="#ffffff" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Animated gradient background" android:textColor="#88ffffff" android:textSize="12sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_live_wallpaper"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Grid Size -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="APP GRID" android:textSize="11sp" android:textColor="#88ffffff"
            android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1a1a2e" app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Grid Columns" android:textColor="#ffffff" android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button android:id="@+id/btn_grid4"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="4" android:layout_marginEnd="8dp"
                        android:backgroundTint="#302b63" android:textColor="#ffffff"/>
                    <Button android:id="@+id/btn_grid5"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="5"
                        android:backgroundTint="#302b63" android:textColor="#ffffff"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Icon Size -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ICON SIZE" android:textSize="11sp" android:textColor="#88ffffff"
            android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1a1a2e" app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Icon Size" android:textColor="#ffffff" android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_icon_size"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:valueFrom="40" android:valueTo="72" android:stepSize="8"
                    app:thumbColor="#7c6bff" app:trackColorActive="#7c6bff"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- MARCO branding -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="MARCO Launcher v1.0" android:textColor="#44ffffff"
            android:textSize="12sp" android:gravity="center" android:layout_marginTop="16dp"/>

    </LinearLayout>
</ScrollView>
